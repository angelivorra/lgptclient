{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Stop servidor service",
      "type": "shell",
      "command": "sudo systemctl stop servidor.service",
      "problemMatcher": []
    },
    {
      "label": "Start servidor service",
      "type": "shell",
      "command": "sudo systemctl start servidor.service",
      "problemMatcher": []
    },
    {
      "label": "Restart servidor service",
      "type": "shell",
      "command": "sudo systemctl restart servidor.service",
      "problemMatcher": []
    },
    {
      "label": "LGPT",
      "type": "shell",
      "command": "/home/angel/LGPT/bin/lgpt.x64",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "MIDI Monitor (tkinter)",
      "type": "shell",
      "command": "${workspaceFolder}/midi_monitor/venv/bin/python ${workspaceFolder}/midi_monitor/main.py",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "MIDI Monitor Linux (Kirigami)",
      "type": "shell",
      "command": "${workspaceFolder}/midi_monitor_linux/venv/bin/python ${workspaceFolder}/midi_monitor_linux/main.py",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Convierte Samples",
      "type": "shell",
      "command": "${workspaceFolder}/bin/venv/bin/python ${workspaceFolder}/bin/genera_samples.py",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "TCP Monitor Linux",
      "type": "shell",
      "command": "${workspaceFolder}/tcp_monitor_linux/run.sh",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Genera Imágenes",
      "type": "shell",
      "command": "${workspaceFolder}/venv/bin/python ${workspaceFolder}/bin/genera.py ${input:terminal}",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Ansible: actualiza clientes",
      "type": "shell",
      "command": "ansible-playbook actualiza.yaml -i inventario",
      "options": {
        "cwd": "${workspaceFolder}/ansible"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ],
  "inputs": [
    {
      "id": "terminal",
      "type": "pickString",
      "description": "Terminal destino",
      "options": ["ordenador", "maleta", "sombrilla"],
      "default": "ordenador"
    }
  ]
}
