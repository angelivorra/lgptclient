{
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Ansible Playbook: actualiza maletas",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/venv/bin/ansible-playbook", // Assumes ansible-playbook is in your PATH
            "args": [
                "${workspaceFolder}/ansible/actualiza-maletas.yaml",
                "-i",
                "${workspaceFolder}/ansible/inventario"
            ],
            "cwd": "${workspaceFolder}/ansible",
            "console": "integratedTerminal"
        },
        {
            "name": "Ansible Playbook: actualiza todo",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/venv/bin/ansible-playbook", // Assumes ansible-playbook is in your PATH
            "args": [
                "${workspaceFolder}/ansible/actualiza-todo.yaml",
                "-i",
                "${workspaceFolder}/ansible/inventario"
            ],
            "cwd": "${workspaceFolder}/ansible",
            "console": "integratedTerminal"
        },
        {
            "name": "Debug servidor (server-copilot.py)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/bin/server-copilot.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONUNBUFFERED": "1"
            },
            "justMyCode": false,
            "preLaunchTask": "Stop servidor service"
        }
    ]
}